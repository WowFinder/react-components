{
    "name": "@wowfinder/react-components",
    "type": "commonjs",
    "version": "0.0.19",
    "description": "React component library for the WowFinder apps",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/WowFinder/react-components.git"
    },
    "author": "Edurne Pascual <herenvardo@gmail.com>",
    "license": " GPL-3.0-or-later",
    "scripts": {
        "lint": "eslint . --ext js,ts,jsx,tsx",
        "lint:fix": "eslint . --ext js,ts,jsx,tsx --fix",
        "format": "prettier --write --log-level=warn \"src/**/*.{js,ts,jsx,tsx,json,json5}\"",
        "format:check": "prettier --check \"src/**/*.{js,ts,jsx,tsx,json,json5}\"",
        "precommit": "npm-run-all -s lint:fix format test:coverage build skott:circular",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:storybook": "test-storybook",
        "test:watch": "vitest watch",
        "skott:web": "skott -nit --displayMode=webapp --trackThirdPartyDependencies --trackBuiltinDependencies src/",
        "skott:circular": "skott -nit --showCircularDependencies --displayMode=raw",
        "checks:quick": "npm-run-all -pc lint build:tsc",
        "checks:fix": "npm-run-all -sc lint:fix format build:tsc",
        "checks:standard": "npm-run-all -sc lint format:check build:tsc test skott:circular",
        "checks:full": "npm-run-all -sc lint:fix format test:coverage build skott:circular",
        "checks:pedantic": "npm-run-all -sc lint format:check test:coverage build skott:circular",
        "build-storybook": "storybook build",
        "build:pre": "rimraf dist",
        "build:tsc": "tsc",
        "build:clean-tests": "find ./dist -name '__tests__' | xargs rm -rf",
        "build:setup": "node dist/.setup.js",
        "build:pack": "cd dist && yarn pack && mv package.tgz ../package.tgz && cd ..",
        "build": "npm-run-all -s build:pre build:tsc build:clean-tests build:setup build:pack build-storybook",
        "prepublishOnly": "yarn version apply && yarn run checks:pedantic && yarn build",
        "prepare": "yarn build",
        "storybook": "storybook dev -p 6006",
        "chromatic": "npx chromatic"
    },
    "dependencies": {
        "@wowfinder/asset-schemas": "^0.0.26",
        "@wowfinder/model": "^0.0.27",
        "@wowfinder/translations": "^0.0.10",
        "@wowfinder/ts-enums": "^0.0.32",
        "@wowfinder/ts-utils": "^0.1.20",
        "globals": "^17.4.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "styled-components": "^6.3.11"
    },
    "devDependencies": {
        "@eslint/compat": "^1.4.1",
        "@playwright/test": "^1.58.2",
        "@storybook/addon-essentials": "^8.6.14",
        "@storybook/addon-interactions": "^8.6.14",
        "@storybook/addon-links": "^8.6.18",
        "@storybook/addon-onboarding": "^8.6.18",
        "@storybook/blocks": "^8.6.14",
        "@storybook/react": "^8.6.18",
        "@storybook/react-vite": "^8.6.18",
        "@storybook/test": "^8.6.15",
        "@storybook/test-runner": "^0.22.0",
        "@stylistic/eslint-plugin-js": "^4.2.0",
        "@testing-library/dom": "^10.4.0",
        "@testing-library/react": "^16.3.2",
        "@trivago/prettier-plugin-sort-imports": "^5.2.2",
        "@tsconfig/recommended": "^1.0.13",
        "@types/jest": "^30.0.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/styled-components": "^5.1.36",
        "@typescript-eslint/eslint-plugin": "^8.57.1",
        "@typescript-eslint/parser": "^8.57.1",
        "@typescript-eslint/utils": "^8.57.1",
        "@vitest/coverage-v8": "^3.2.4",
        "c8": "^10.1.3",
        "chromatic": "^11.29.0",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.2",
        "eslint-plugin-deprecation": "^3.0.0",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-istanbul": "^0.1.2",
        "eslint-plugin-misc": "^3.3.1",
        "eslint-plugin-n": "^17.24.0",
        "eslint-plugin-node": "^11.1.0",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-promise": "^7.2.1",
        "i18next": "^25.8.18",
        "i18next-browser-languagedetector": "^8.2.1",
        "i18next-http-backend": "^3.0.2",
        "jest": "^30.3.0",
        "jest-environment-jsdom": "^30.3.0",
        "npm-run-all": "^4.1.5",
        "prettier": "^3.8.1",
        "react-i18next": "^16.5.8",
        "rimraf": "^6.1.3",
        "rxjs": "^7.8.2",
        "skott": "^0.35.4",
        "storybook": "^8.6.18",
        "storybook-react-i18next": "^3.3.1",
        "ts-jest": "^29.4.6",
        "tsd": "^0.33.0",
        "typescript": "^5.9.3",
        "vite": "^6.4.1",
        "vitest": "^3.2.4"
    },
    "packageManager": "yarn@4.13.0"
}
